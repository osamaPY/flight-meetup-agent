# ─────────────────────────────────────────────────────────────
#  Flight Meetup Optimizer - environment configuration
#  Copy to .env  (cp .env.example .env)  and fill in your values.
#  .env is gitignored - never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Telegram (required to run the bot) ──
# Get a token from @BotFather; TELEGRAM_CHAT_ID is your own numeric user id
# (message @userinfobot) - it's the owner/admin account.
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_numeric_user_id

# Set to 1 to make the bot invite-only (recommended before sharing publicly).
REQUIRE_INVITE_CODE=0

# Product defaults (make a fork yours without editing Python).
# Participant defaults are used by the CLI/fallback search. Telegram groups can
# still add their own members and origins from chat.
DEFAULT_PARTICIPANT_A_LABEL=You
DEFAULT_ORIGINS_A=BGY,MXP,LIN
DEFAULT_PARTICIPANT_B_LABEL=Friend
DEFAULT_ORIGINS_B=RIX

# Search panel defaults shown in the Telegram bot.
DEFAULT_SEARCH_START_OFFSET_DAYS=14
DEFAULT_SEARCH_END_OFFSET_DAYS=42
DEFAULT_MIN_NIGHTS=2
DEFAULT_MAX_NIGHTS=4
DEFAULT_LUGGAGE=carryon_10kg
DEFAULT_INCLUDE_TRANSFERS=1
DEFAULT_DIRECT_ONLY=0
DEFAULT_MAX_STOPS=2
DEFAULT_DESTINATION_UNIVERSE=europe

# ── DeepSeek LLM - optional AI concierge in the bot ──
# Powers the ✨ "Which should we pick?" recommendation and ✨ "Things to do"
# city ideas. Leave blank to disable (the bot works fine without it).
# Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Travelpayouts / Aviasales - optional, FREE flight-data API ──
# Recommended for servers: it's a real API, so it keeps working from a VPS/
# datacenter IP where Google Flights and airline sites get blocked. Prices are
# cached (approximate) - good for ranking cities, verify before booking.
# Free affiliate token at https://www.travelpayouts.com. Leave blank to skip.
TRAVELPAYOUTS_TOKEN=

# Amadeus - optional GDS provider (enabled only when both values are set).
# Use hostname "test" for self-service test credentials, or "production" if
# your account is provisioned for it.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOSTNAME=test

# ── Duffel - optional PAID GDS provider (owner searches only) ──
# Leave blank to run fully free (Ryanair + Google). DUFFEL_DAILY_BUDGET caps
# paid calls per day; set 0 to disable Duffel entirely.
DUFFEL_TOKEN=
DUFFEL_DAILY_BUDGET=50

# ── Search knobs (CLI / legacy default search) ──
TARGET_PRICE_EUR=200
# Provider-call budget per search. Set 0 for unlimited/brute-force.
MAX_API_CALLS_PER_RUN=5000
# auto = exact-date breadth first when capped, full flexible dates when unlimited.
# Other values: exact, flexible, all.
SEARCH_DATE_VARIANT_MODE=auto
