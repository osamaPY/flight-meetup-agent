# ─────────────────────────────────────────────────────────────
#  Flight Meetup Optimizer - environment configuration
#  Copy to .env  (cp .env.example .env)  and fill in your values.
#  .env is gitignored - never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Telegram (required to run the bot) ──
# Get a token from @BotFather; TELEGRAM_CHAT_ID is your own numeric user id
# (message @userinfobot) - it's the owner/admin account.
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_numeric_user_id

# Set to 1 to make the bot invite-only (recommended before sharing publicly).
REQUIRE_INVITE_CODE=0

# ── DeepSeek LLM - optional AI concierge in the bot ──
# Powers the ✨ "Which should we pick?" recommendation and ✨ "Things to do"
# city ideas. Leave blank to disable (the bot works fine without it).
# Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Travelpayouts / Aviasales - optional, FREE flight-data API ──
# Recommended for servers: it's a real API, so it keeps working from a VPS/
# datacenter IP where Google Flights and airline sites get blocked. Prices are
# cached (approximate) - good for ranking cities, verify before booking.
# Free affiliate token at https://www.travelpayouts.com. Leave blank to skip.
TRAVELPAYOUTS_TOKEN=

# ── Duffel - optional PAID GDS provider (owner searches only) ──
# Leave blank to run fully free (Ryanair + Google). DUFFEL_DAILY_BUDGET caps
# paid calls per day; set 0 to disable Duffel entirely.
DUFFEL_TOKEN=
DUFFEL_DAILY_BUDGET=50

# ── Search knobs (CLI / legacy default search) ──
TARGET_PRICE_EUR=200
MAX_API_CALLS_PER_RUN=300

# ── API server (future auth; not required for local use) ──
JWT_SECRET=change_me_to_something_random
